# ================================================================
# FORGE POINT PROPERTY SERVICES — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ================================================================

# ── Database (Railway PostgreSQL) ────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── NextAuth.js v5 ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""                    # Generate: openssl rand -base64 32

# ── Google OAuth (primary auth) ──────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Google APIs ──────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""    # Maps JavaScript API
GOOGLE_CALENDAR_API_KEY=""            # Phase 2

# ── Cloudinary (image storage) ───────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Unsplash (stock photos) ──────────────────────────────────────
UNSPLASH_ACCESS_KEY=""

# ── SendGrid (transactional email) ───────────────────────────────
SENDGRID_API_KEY=""                   # Phase 2
SENDGRID_FROM_EMAIL="info@cre8forge.com"

# ── Twilio (SMS) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""                 # Phase 2
TWILIO_AUTH_TOKEN=""                  # Phase 2
TWILIO_PHONE_NUMBER=""                # Phase 2

# ── Stripe (payments) ────────────────────────────────────────────
STRIPE_SECRET_KEY=""                  # Phase 2
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="" # Phase 2
STRIPE_WEBHOOK_SECRET=""              # Phase 2

# ── Anthropic (AI chatbot + social content) ──────────────────────
ANTHROPIC_API_KEY=""                  # Phase 2

# ── Meta (Facebook + Instagram publishing) ───────────────────────
META_APP_ID=""                        # Phase 2
META_APP_SECRET=""                    # Phase 2
